# Copy to .env and fill in. run.sh loads this automatically.

# Required for real remediation (omit and set DRY_RUN=1 to simulate)
DEVIN_API_KEY=
# GitHub token with repo scope on the fork (issues, PRs, merge)
GITHUB_TOKEN=

# Target fork
REPO=cooco119/superset

# Slack (optional — bot mode needs both tokens; SLACK_CHANNEL for proactive posts)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL=C0BJXDTSQCS
# Or webhook-only mode instead of the bot:
# SLACK_WEBHOOK_URL=

# Behavior
DRY_RUN=0
AUTO_MERGE=1
MAX_PARALLEL_SESSIONS=3
POLL_INTERVAL=60
GITHUB_POLL_INTERVAL_SEC=30
SCAN_INTERVAL_MIN=0
HOURS_PER_ISSUE=4

# Shown in Slack status/report replies (e.g. your tunnel URL)
DASHBOARD_URL=http://localhost:8000

# Optional OpenTelemetry OTLP endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=
